{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.minepi.com https://minepi.com"
        }
      ]
    },
    {
      "source": "/validation-key.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/validation-key.txt",
      "destination": "/validation-key.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
